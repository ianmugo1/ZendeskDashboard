# Zendesk API credentials
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=agent@example.com
ZENDESK_API_TOKEN=your-api-token

# Redis
REDIS_URL=redis://localhost:6379
SNAPSHOT_KEY=zendesk:snapshot

# Cache backend: redis or file
CACHE_BACKEND=redis
SNAPSHOT_FILE_PATH=./data/zendesk-snapshot.json

# Polling
POLL_INTERVAL_SECONDS=60
MAX_TICKET_SCAN=500
MAX_SOLVED_AUDIT_TICKETS=300
MAX_AGENT_SCAN=500
DASHBOARD_TIMEZONE=Europe/Dublin

# API service
METRICS_API_PORT=4000
METRICS_API_HOST=0.0.0.0
SNAPSHOT_STALE_AFTER_SECONDS=180

# Dashboard service
DASHBOARD_PORT=3000
DASHBOARD_API_BASE_URL=http://localhost:4000
DASHBOARD_BASIC_AUTH_USERNAME=tv
DASHBOARD_BASIC_AUTH_PASSWORD=change-me
DASHBOARD_REFRESH_SECONDS=20
NEXT_PUBLIC_ZENDESK_BASE_URL=https://emeraldpark.zendesk.com
METRICS_PUBLIC_BASE_URL=http://localhost:4000
DASHBOARD_PUBLIC_URL=http://localhost:3000
WIDGETS_TOP_SOLVERS=true
WIDGETS_TICKETS_BY_TAG=true
WIDGETS_UNASSIGNED=true
WIDGETS_ATTENTION=true
WIDGETS_DAILY_VOLUME=true
THRESHOLD_UNSOLVED_WARN=80
THRESHOLD_ATTENTION_WARN=10
THRESHOLD_UNASSIGNED_WARN=10
SLA_FIRST_RESPONSE_TARGET_HOURS=2
SLA_RESOLUTION_TARGET_HOURS=72
HIGH_PRIORITY_STALE_HOURS=8
TEAMS_NOTIFICATIONS_ENABLED=false
TEAMS_WEBHOOK_URL=
TEAMS_NOTIFY_INTERVAL_SECONDS=3600
SCREENSHOT_CAPTURE_URL=http://localhost:3000
SCREENSHOT_FILE_PATH=./data/latest-dashboard.png
SCREENSHOT_PUBLIC_URL=
SCREENSHOT_ACCESS_TOKEN=
SCREENSHOT_BROWSER_PATH=
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080
SCREENSHOT_TIMEOUT_MS=45000
SCREENSHOT_BASIC_AUTH_USERNAME=tv
SCREENSHOT_BASIC_AUTH_PASSWORD=change-me

# Dashboard config
CONFIG_FILE_PATH=./config/dashboard.config.json
TICKETS_BY_TAG_LIST=vip,payment_issue,refund,season_pass,website
